APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:99FmLjME6L7rn2HZ76Mq6Iw0PM0AOoEZxBQIsf7961M=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=test-db
DB_PORT=5432
DB_DATABASE=test
DB_USERNAME=test_user
DB_PASSWORD=test_password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue driver: rabbitmq (vladimir-yuldashev/laravel-queue-rabbitmq)
# Dev worker (composer run dev):    queue:work rabbitmq --queue=products,orders,reindex
# Docker workers (docker-compose):  3 dedicated containers, one per domain queue
QUEUE_CONNECTION=rabbitmq
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
# Fallback queue for jobs without explicit $queue. Domain queues (products/orders/reindex)
# are set per-job via $this->onQueue() and never use this value.
RABBITMQ_QUEUE=default

# Runtime tuning for docker-compose queue workers (--sleep / --timeout / --max-time flags).
# Dev worker uses hardcoded values: --sleep=3 --timeout=120 (covers reindex worst case).
# QUEUE_WORKER_MAX_TIME: graceful restart interval (seconds). Clears Elasticsearch dead-node
# cache in SimpleNodePool after ES outage. Workers restart via docker restart: unless-stopped.
QUEUE_WORKER_SLEEP=3
QUEUE_WORKER_PRODUCTS_TIMEOUT=60
QUEUE_WORKER_ORDERS_TIMEOUT=60
QUEUE_WORKER_REINDEX_TIMEOUT=120
QUEUE_WORKER_MAX_TIME=3600

ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_TIMEOUT=2
ELASTICSEARCH_INDEX_PRODUCTS=products_v1
ELASTICSEARCH_INDEX_ORDERS=orders_v1

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=test-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
